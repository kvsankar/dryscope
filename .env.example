# dryscope environment variables
# Copy this file to .env and fill in the values you need.
# Only required if using --verify for LLM-based cluster verification.

# LLM model to use for verification (default: claude-haiku-4-5-20251001)
# DRYSCOPE_LLM_MODEL=claude-haiku-4-5-20251001

# Set the API key for your chosen provider below.

# Anthropic (for claude-haiku-4-5-20251001, claude-sonnet-4-6, etc.)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for gpt-4o-mini, gpt-4o, etc.)
# OPENAI_API_KEY=sk-...

# Google (for gemini/gemini-2.0-flash, etc.)
# GEMINI_API_KEY=...

# Azure OpenAI
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/

# AWS Bedrock (uses AWS credentials)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# Local Ollama (no key needed, just run ollama serve)
# Use --llm-model ollama/llama3
